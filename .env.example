# ==== Núcleo ====
# Segredo do JWT — OBRIGATÓRIO, mínimo 32 caracteres. Sem ele o servidor não sobe.
JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio-de-32-chars
# String de conexão do banco (Postgres em produção)
DATABASE_URL=postgresql://autosales:senha@localhost:5432/autosales
PORT=3000
NODE_ENV=development
# Origens permitidas no CORS (separadas por vírgula). Em produção, defina!
ALLOWED_ORIGINS=https://app.suaclinica.com.br
# URL do frontend, usada para montar links de agendamento
FRONTEND_URL=http://localhost:8080

# ==== SuperAdmin inicial (criado no 1º boot se não existir) ====
SUPERADMIN_EMAIL=admin@suaempresa.com
SUPERADMIN_PASSWORD=troque-esta-senha-forte

# ==== WhatsApp — Meta Cloud API (canal oficial de produção) ====
# Token que você define no painel da Meta e repete aqui (handshake do webhook)
META_VERIFY_TOKEN=defina-um-token-de-verificacao
# App Secret do App da Meta — valida a assinatura HMAC dos webhooks
META_APP_SECRET=seu-app-secret-da-meta
# Versão da Graph API (opcional; default v21.0)
META_GRAPH_VERSION=v21.0

# ==== WhatsApp — Baileys (EXPERIMENTAL, não-oficial, risco de ban) ====
# Deixe desligado em produção. Só habilite para testes locais.
ENABLE_BAILEYS=false

# ==== Google Calendar (agendamento real) ====
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback

# ==== IA (fallback global; tenants podem trazer a própria chave) ====
GEMINI_API_KEY=
OPENAI_API_KEY=

# ==== Docker Compose ====
POSTGRES_PASSWORD=defina-uma-senha-para-o-postgres
