# ─────────────────────────────────────────────────────────────
# AutoSales / VendAI — variáveis de ambiente
# Copie para .env e preencha. NUNCA comite o .env real.
# ─────────────────────────────────────────────────────────────

# App
NODE_ENV=production
PORT=3000

# ── OBRIGATÓRIO: a app NÃO sobe sem isto ──────────────────────
# Segredo de assinatura do JWT. Sem fallback: ausente = boot falha.
# Gere: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=

# ── OBRIGATÓRIO: webhook do WhatsApp falha fechado sem isto ────
# Segredo compartilhado entre a API e os conectores (Baileys/Meta).
# Gere como o JWT_SECRET acima.
INTERNAL_WEBHOOK_SECRET=

# ── Banco de dados ────────────────────────────────────────────
DATABASE_URL=postgresql://usuario:senha@host:5432/autosales

# ── CORS ──────────────────────────────────────────────────────
# Lista separada por vírgula das origens permitidas.
# Em produção, se vazio, o cross-origin é bloqueado (same-origin continua ok).
ALLOWED_ORIGINS=https://app.seudominio.com

# ── SuperAdmin inicial ────────────────────────────────────────
# Só é criado no primeiro boot se SUPERADMIN_PASSWORD estiver definido.
# Nada de senha padrão "admin". Troque a senha no primeiro login.
SUPERADMIN_EMAIL=admin@seudominio.com
SUPERADMIN_PASSWORD=

# ── IA (Gemini) ───────────────────────────────────────────────
# Usada como fallback quando o tenant não tem chave própria.
GEMINI_API_KEY=

# ── Google Calendar (OAuth) — agendamento real ────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://app.seudominio.com/api/google/callback

# ── WhatsApp Cloud API (Meta) — canal oficial ─────────────────
# (Preencher ao integrar o caminho oficial do Sprint 2.)
META_VERIFY_TOKEN=
META_APP_SECRET=
