# ==== Núcleo ====
# Segredo do JWT — OBRIGATÓRIO, mínimo 32 caracteres. Sem ele o servidor não sobe.
JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio-de-32-chars
# String de conexão do banco (Postgres em produção)
DATABASE_URL=postgresql://autosales:senha@localhost:5432/autosales
PORT=3000
NODE_ENV=development
# Origens permitidas no CORS (separadas por vírgula). Em produção, defina!
ALLOWED_ORIGINS=https://app.suaclinica.com.br
# URL do frontend, usada para montar links de agendamento
FRONTEND_URL=http://localhost:8080

# ==== SuperAdmin inicial (criado no 1º boot se não existir) ====
SUPERADMIN_EMAIL=admin@suaempresa.com
SUPERADMIN_PASSWORD=troque-esta-senha-forte

# ==== WhatsApp — Meta Cloud API (canal oficial de produção) ====
# Token que você define no painel da Meta e repete aqui (handshake do webhook)
META_VERIFY_TOKEN=defina-um-token-de-verificacao
# App Secret do App da Meta — valida a assinatura HMAC dos webhooks
META_APP_SECRET=seu-app-secret-da-meta
# Versão da Graph API (opcional; default v21.0)
META_GRAPH_VERSION=v21.0

# ==== WhatsApp — Baileys (EXPERIMENTAL, não-oficial, risco de ban) ====
# Deixe desligado em produção. Só habilite para testes locais.
ENABLE_BAILEYS=false

# ==== Google Calendar (agendamento real) ====
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback

# ==== IA (fallback global; tenants podem trazer a própria chave) ====
GEMINI_API_KEY=
OPENAI_API_KEY=

# ==== Pagamento (Mercado Pago) ====
# Token de acesso do Mercado Pago (checkout hospedado). Sem ele, o checkout
# cai em modo sandbox interno para testes.
MP_ACCESS_TOKEN=
# Segredo compartilhado que valida a assinatura HMAC do webhook de pagamento.
PAYMENT_WEBHOOK_SECRET=defina-um-segredo-para-o-webhook-de-pagamento
# URL pública do backend (para o gateway chamar o webhook). Ex.: https://api.seudominio.com
PUBLIC_URL=

# ==== Assinatura / Trial ====
# Dias de trial gratuito ao cadastrar (default 14)
TRIAL_DAYS=7

# ═══════ E-mail transacional (verificação, reset de senha) ═══════
# Qualquer SMTP funciona — Resend, SendGrid, AWS SES, Gmail App Password, etc.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="AutoSales <no-reply@seu-dominio.com>"

# ==== Observabilidade ====
# Nível de log do pino (trace|debug|info|warn|error|fatal). Default: info em prod.
LOG_LEVEL=info
# DSN do Sentry (opcional). Já vem com @sentry/node instalado; basta definir.
SENTRY_DSN=

# ==== Pagamento ====
# Gateway padrão quando o painel admin não define: MERCADO_PAGO | STRIPE
PAYMENT_PROVIDER=MERCADO_PAGO
# (as chaves reais são configuradas no painel admin ou nas envs abaixo)
# MP_ACCESS_TOKEN=
# PAYMENT_WEBHOOK_SECRET=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PUBLISHABLE_KEY=   # pk_live_… / pk_test_… (checkout embutido; pode ser pública)

# ==== Armazenamento de mídia do catálogo ====
# Sem S3_BUCKET → grava em disco local (UPLOAD_DIR, servido em /uploads).
# Em container efêmero, monte um VOLUME persistente nesse caminho.
UPLOAD_DIR=
# Object storage S3-compatível (recomendado em produção — Cloudflare R2, AWS S3, MinIO):
S3_BUCKET=
S3_REGION=auto
S3_ENDPOINT=            # ex.: https://<accountid>.r2.cloudflarestorage.com (R2/MinIO); vazio p/ AWS
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=          # base pública dos arquivos, ex.: https://cdn.seu-dominio.com

# ==== Docker Compose ====
POSTGRES_PASSWORD=defina-uma-senha-para-o-postgres
